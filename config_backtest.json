{
    "$schema": "https://schema.freqtrade.io/schema.json",

    "bot_name": "ZeroLag-Backtest",
    "strategy": "ZeroLagTrend",

    "max_open_trades": 5,
    "stake_currency": "USDT",
    "stake_amount": 190,
    "tradable_balance_ratio": 0.95,
    "amend_last_stake_amount": true,
    "fiat_display_currency": "USD",

    "timeframe": "1h",
    "dry_run": true,
    "dry_run_wallet": 1000,

    "cancel_open_orders_on_exit": true,

    "unfilledtimeout": {
        "entry": 10,
        "exit": 30,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },

    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },

    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },

    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {
            "options": {
                "defaultType": "spot",
                "fetchMarkets": ["spot"]
            }
        },
        "ccxt_async_config": {
            "options": {
                "defaultType": "spot",
                "fetchMarkets": ["spot"]
            }
        },
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "SOL/USDT",
            "LTC/USDT",
            "ATOM/USDT",
            "LINK/USDT",
            "XRP/USDT",
            "ADA/USDT",
            "DOT/USDT"
        ],
        "pair_blacklist": []
    },

    "pairlists": [
        {"method": "StaticPairList"}
    ],

    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },

    "api_server": {
        "enabled": false,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8083,
        "username": "zerolag",
        "password": "backtest",
        "jwt_secret_key": "backtestSecretKey123"
    },

    "initial_state": "running",
    "force_entry_enable": false,

    "internals": {
        "process_throttle_secs": 5
    }
}
